# Cookie encryption keys (required)
# Generate with: openssl rand -base64 32
COOKIE_HASH_KEY=<base64-32-or-64-bytes>
COOKIE_BLOCK_KEY=<base64-16-24-or-32-bytes>

# Database (required)
DATABASE_URL=postgresql://christjesus:christjesus@localhost:5432/christjesus

# Application
ENVIRONMENT=development
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080
SESSION_MAX_AGE_SEC=604800

# Auth0 (required)
AUTH0_DOMAIN=<your-tenant>.us.auth0.com
AUTH0_CLIENT_ID=<auth0-client-id>
AUTH0_CLIENT_SECRET=<auth0-client-secret>
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:8080/auth/callback
AUTH0_LOGOUT_URL=http://localhost:8080/

# Auth0 Management API — M2M client for profile updates (required)
# After terraform apply: terraform output -raw auth0_mgmt_client_secret
AUTH0_MGMT_CLIENT_ID=<terraform-output>
AUTH0_MGMT_CLIENT_SECRET=<terraform-output>

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Transactional email - Resend (required)
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
EMAIL_FROM_ADDRESS=

# Tigris object storage (required)
S3_BUCKET_NAME=<bucket-name>
OBJECT_STORE_ENDPOINT=https://t3.storage.dev
TIGRIS_ACCESS_KEY=<tigris-access-key>
TIGRIS_SECRET_KEY=<tigris-secret-key>

# USPS address validation (required)
USPS_CONSUMER_KEY=<usps-consumer-key>
USPS_CONSUMER_SECRET=<usps-consumer-secret>

# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=<ngrok-authtoken>
# https://dashboard.ngrok.com/api-keys
NGROK_API_KEY=<ngrok-api-key>
