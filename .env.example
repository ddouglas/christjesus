# Cookie encryption keys (required)
# Generate with: openssl rand -base64 32
export COOKIE_HASH_KEY=<base64-32-or-64-bytes>
export COOKIE_BLOCK_KEY=<base64-16-24-or-32-bytes>

# Database (required)
export DATABASE_URL=postgresql://christjesus:christjesus@localhost:5432/christjesus

# Application
export ENVIRONMENT=development
export SERVER_PORT=8080
export APP_BASE_URL=http://localhost:8080
export SESSION_MAX_AGE_SEC=604800

# Auth0 (required)
export AUTH0_DOMAIN=<your-tenant>.us.auth0.com
export AUTH0_CLIENT_ID=<auth0-client-id>
export AUTH0_CLIENT_SECRET=<auth0-client-secret>
export AUTH0_AUDIENCE=
export AUTH0_CALLBACK_URL=http://localhost:8080/auth/callback
export AUTH0_LOGOUT_URL=http://localhost:8080/

# Auth0 Management API — M2M client for profile updates (required)
# After terraform apply: terraform output -raw auth0_mgmt_client_secret
export AUTH0_MGMT_CLIENT_ID=<terraform-output>
export AUTH0_MGMT_CLIENT_SECRET=<terraform-output>

# Stripe (optional)
export STRIPE_SECRET_KEY=sk_test_...
export STRIPE_PUBLISHABLE_KEY=pk_test_...
export STRIPE_WEBHOOK_SECRET=whsec_...

# Transactional email - Resend (optional)
export RESEND_API_KEY=re_...
export RESEND_WEBHOOK_SECRET=whsec_...
export EMAIL_FROM_ADDRESS=noreply@cja.onetwentyseven.dev

# Tigris object storage (required)
export S3_BUCKET_NAME=<bucket-name>
export OBJECT_STORE_ENDPOINT=https://t3.storage.dev
export TIGRIS_ACCESS_KEY=<tigris-access-key>
export TIGRIS_SECRET_KEY=<tigris-secret-key>

# USPS address validation (required)
export USPS_CONSUMER_KEY=<usps-consumer-key>
export USPS_CONSUMER_SECRET=<usps-consumer-secret>
